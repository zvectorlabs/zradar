# Rust (workspace root and per-crate build dirs)
target/
target-just/
**/*.rs.bk
*.pdb

# Node.js (examples/nodejs)
node_modules/
npm-debug.log*
yarn-error.log*

# Python (examples/python)
.venv/
__pycache__/
*.py[cod]

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Local configuration (use config.example.toml as template)
config.toml
config.toml.backup
*.local.toml

# Environment
.env
.env.*
!.env.example

# Logs
*.log

# Local / test data
data-test/

# Data directories (preserve structure but ignore contents)
data/trace-batches/*
!data/trace-batches/.gitkeep
data/postgres/*
!data/postgres/.gitkeep
data/parquet-files/*
data/wal/*
!data/wal/.gitkeep

# Sibling workspace repos (when checked out next to zradar)
zradar-plans/
